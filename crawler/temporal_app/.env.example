# Copy to .env and adjust. Loaded by run_worker.sh.

# --- Temporal (self-hosted, no TLS) ---
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# --- Transform pipeline ---
WAREHOUSE_DSN=postgresql://admin:admin123@localhost:5432/car_recsys
DBT_DIR=/home/duc-nguyen16/car-recsys-consultant-chatbot/car-recsys-system/dbt
MATVIEWS_SQL=/home/duc-nguyen16/car-recsys-consultant-chatbot/car-recsys-system/database/matviews.sql

# --- GCS (load_bronze reads bronze JSON; crawler upload_gcs writes it) ---
GCS_BUCKET=incremental_raw
GCP_PROJECT_ID=cobalt-bond-494609-a6
GOOGLE_APPLICATION_CREDENTIALS=/home/duc-nguyen16/.config/gcloud/application_default_credentials.json

# --- ML: embeddings ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=car_chatbot_vectors
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIM=3072
